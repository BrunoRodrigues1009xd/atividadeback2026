const fs = require('fs');
const path = require('path');
const express = require('express');

const PORT = 3000;
const BASEDADOS = path.join(__dirname, "banco.txt");
const app = express();
app.use(express.static(path.join(__dirname, 'public')));
app.use(express.json());

app.listen(PORT, () => {
    console.log(`Servidor rodando em http://localhost:${PORT}`)});

app.get('/api/public', async (requisicao, respostas) => {
    try {
        const produtos = await lerBaseDados();
        respostas.json(produtos);
    } catch(erro){
        console.error("Não foi possível acessar o Banco de Dados: " + erro);
        respostas.status(500).send("Não foi possível carregar os produtos.");
    }
});

async function lerBaseDados() {
    const dados = (await fs.promises.readFile(BASEDADOS, "utf-8"))
                                .trim()
                                .split(/\r?\n/);
    const produtos = [];
    dados.forEach(dado => {
        produtos.push(new Produtos(dado));
    });
    return produtos;
}

